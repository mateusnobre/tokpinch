# =============================================================================
# TokPinch — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=4100
NODE_ENV=development
LOG_LEVEL=info          # fatal | error | warn | info | debug | trace

# -----------------------------------------------------------------------------
# Provider API Keys  (NEVER logged or exposed — kept server-side only)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=                    # Required — forwarded to Anthropic
OPENAI_API_KEY=                       # Optional — for OpenAI provider support

# -----------------------------------------------------------------------------
# Dashboard Authentication
# -----------------------------------------------------------------------------
DASHBOARD_PASSWORD=changeme           # Required — min 8 chars
JWT_SECRET=                           # Optional — auto-generated if blank

# -----------------------------------------------------------------------------
# Budget Controls (USD)
# Leave blank for no limit.
# -----------------------------------------------------------------------------
BUDGET_DAILY=5.00                     # e.g. 5.00
BUDGET_MONTHLY=50.00                  # e.g. 50.00

# -----------------------------------------------------------------------------
# Alerts — Telegram
# -----------------------------------------------------------------------------
ALERT_TELEGRAM_TOKEN=                 # Bot token from @BotFather
ALERT_TELEGRAM_CHAT_ID=              # Your chat / group ID

# -----------------------------------------------------------------------------
# Alerts — Email (SMTP)
# -----------------------------------------------------------------------------
ALERT_EMAIL_TO=                       # e.g. you@example.com
ALERT_EMAIL_SMTP_HOST=               # e.g. smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=
ALERT_EMAIL_SMTP_PASS=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
SMART_ROUTING_ENABLED=true            # Route to cheapest model that fits
LOOP_DETECTION_ENABLED=true           # Detect & break runaway agent loops

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DB_PATH=./data/tokpinch.db           # SQLite database path

# -----------------------------------------------------------------------------
# CORS (comma-separated origins, blank = same-origin only)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=
